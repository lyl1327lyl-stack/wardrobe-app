import React, { useState, useCallback, useRef, useEffect } from 'react';
import {
  View,
  Text,
  TouchableOpacity,
  StyleSheet,
  Image,
  Alert,
  TextInput,
  SafeAreaView,
  Dimensions,
  ScrollView,
  Animated,
  PanResponder,
  BackHandler,
} from 'react-native';
import { Ionicons } from '@expo/vector-icons';
import { useWardrobeStore } from '../store/wardrobeStore';
import { ClothingItem, OutfitItemPosition } from '../types';
import { theme } from '../utils/theme';

const { width: SCREEN_WIDTH } = Dimensions.get('window');
const CANVAS_ITEM_SIZE = 120;

type OutfitDetailRouteProp = { OutfitDetail: { outfitId: number } };

export function OutfitDetailScreen({ route, navigation }: any) {
  const { outfitId } = route.params as OutfitDetailRouteProp;
  const { outfits, clothing, updateOutfit, deleteOutfit } = useWardrobeStore();
  const outfit = outfits.find((o: any) => o.id === outfitId);

  // 必须在 hooks 之前判断，hooks 不能在条件分支后
  if (!outfit) {
    return (
      <View style={styles.container}>
        <View style={styles.notFound}>
          <Ionicons name="alert-circle-outline" size={48} color={theme.colors.textTertiary} />
          <Text style={styles.notFoundText}>搭配不存在</Text>
          <TouchableOpacity style={styles.backBtn} onPress={() => navigation.goBack()}>
            <Text style={styles.backBtnText}>返回</Text>
          </TouchableOpacity>
        </View>
      </View>
    );
  }

  const [showEditName, setShowEditName] = useState(false);
  const [editName, setEditName] = useState(outfit.name || '');
  const [pendingPositions, setPendingPositions] = useState<Record<number, OutfitItemPosition>>(
    (outfit?.itemPositions || {}) as Record<number, OutfitItemPosition>
  );
  const [pendingItemIds, setPendingItemIds] = useState<number[]>(outfit?.itemIds || []);
  const [isSaving, setIsSaving] = useState(false);
  const [showSaved, setShowSaved] = useState(false);

  const canvasWidth = SCREEN_WIDTH;
  const canvasHeight = SCREEN_WIDTH * 1.2;

  const getItemPosition = (clothingId: number): OutfitItemPosition => {
    return pendingPositions[clothingId] ?? {
      x: canvasWidth / 2 - CANVAS_ITEM_SIZE / 2,
      y: canvasHeight / 2 - CANVAS_ITEM_SIZE / 2,
      scale: 1,
    };
  };

  const outfitItems: ClothingItem[] = pendingItemIds
    .map((id: number) => clothing.find((c: any) => c.id === id))
    .filter(Boolean);

  const availableClothing = clothing.filter(
    (c: any) => !pendingItemIds.includes(c.id) && !c.deletedAt
  );

  const handlePositionChange = useCallback(
    (clothingId: number, x: number, y: number, scale: number) => {
      setPendingPositions(prev => ({
        ...prev,
        [clothingId]: { x, y, scale },
      }));
    },
    []
  );

  const handleRemoveItem = useCallback(
    (item: ClothingItem) => {
      Alert.alert('从搭配移除', `确定要将这件「${item.type}」从搭配中移除吗？`, [
        { text: '取消', style: 'cancel' },
        {
          text: '移除',
          style: 'destructive',
          onPress: () => {
            setPendingItemIds(prev => prev.filter(id => id !== item.id));
            setPendingPositions(prev => {
              const next = { ...prev };
              delete next[item.id];
              return next;
            });
          },
        },
      ]);
    },
    []
  );

  const handleAddFromStrip = useCallback(
    (item: ClothingItem) => {
      const centerX = canvasWidth / 2 - CANVAS_ITEM_SIZE / 2 + Math.random() * 60 - 30;
      const centerY = canvasHeight / 2 - CANVAS_ITEM_SIZE / 2 + Math.random() * 60 - 30;
      setPendingItemIds(prev => [...prev, item.id]);
      setPendingPositions(prev => ({
        ...prev,
        [item.id]: { x: centerX, y: centerY, scale: 1 },
      }));
    },
    []
  );

  const handleSaveName = async () => {
    if (!outfit || !editName.trim()) {
      Alert.alert('请输入搭配名称');
      return;
    }
    await updateOutfit({ ...outfit, name: editName.trim() });
    setShowEditName(false);
  };

  const hasUnsavedChanges =
    JSON.stringify(pendingPositions) !== JSON.stringify(outfit?.itemPositions || {}) ||
    JSON.stringify(pendingItemIds) !== JSON.stringify(outfit?.itemIds || []);

  const handleSavePositions = async () => {
    if (isSaving || !outfit) return;
    setIsSaving(true);
    try {
      await updateOutfit({ ...outfit, itemIds: pendingItemIds, itemPositions: pendingPositions });
      setShowSaved(true);
      setTimeout(() => setShowSaved(false), 1500);
    } finally {
      setIsSaving(false);
    }
  };

  useEffect(() => {
    const backHandler = BackHandler.addEventListener('hardwareBackPress', () => {
      if (hasUnsavedChanges) {
        Alert.alert('有未保存的修改', '确定要放弃修改并退出吗？', [
          { text: '取消', style: 'cancel' },
          { text: '退出', style: 'destructive', onPress: () => setTimeout(() => navigation.goBack(), 0) },
        ]);
        return true;
      }
      return false;
    });
    return () => backHandler.remove();
  }, [hasUnsavedChanges, navigation]);

  const handleDeleteOutfit = useCallback(() => {
    if (!outfit) return;
    Alert.alert('确认删除', `确定要删除搭配「${outfit.name}」吗？删除后不可恢复。`, [
      { text: '取消', style: 'cancel' },
      {
        text: '删除',
        style: 'destructive',
        onPress: async () => {
          await deleteOutfit(outfit.id);
          // 延迟到下一帧再退出，避免在 Alert 回调内立即 unmount 导致的 React hooks 警告
          setTimeout(() => navigation.goBack(), 0);
        },
      },
    ]);
  }, [outfit, deleteOutfit, navigation]);

  const renderCanvasItem = useCallback(
    (item: ClothingItem) => {
      const pos = getItemPosition(item.id);
      return (
        <CanvasItem
          key={item.id}
          item={item}
          itemId={item.id}
          initialX={pos.x}
          initialY={pos.y}
          initialScale={pos.scale}
          size={CANVAS_ITEM_SIZE}
          onPositionChange={(x, y, s) => handlePositionChange(item.id, x, y, s)}
          onRemove={() => handleRemoveItem(item)}
        />
      );
    },
    [getItemPosition, handlePositionChange, handleRemoveItem]
  );

  return (
    <View style={styles.container}>
      {/* Header */}
      <View style={styles.header}>
        <TouchableOpacity
          onPress={() => {
            if (hasUnsavedChanges) {
              Alert.alert('有未保存的修改', '确定要放弃修改并退出吗？', [
                { text: '取消', style: 'cancel' },
                { text: '退出', style: 'destructive', onPress: () => setTimeout(() => navigation.goBack(), 0) },
              ]);
            } else {
              navigation.goBack();
            }
          }}
          activeOpacity={0.7}
        >
          <Ionicons name="chevron-back" size={24} color={theme.colors.text} />
        </TouchableOpacity>

        {showEditName ? (
          <View style={styles.nameEditContainer}>
            <TextInput
              style={styles.nameInput}
              value={editName}
              onChangeText={setEditName}
              autoFocus
              onBlur={handleSaveName}
              onSubmitEditing={handleSaveName}
              maxLength={20}
            />
            <TouchableOpacity onPress={handleSaveName} activeOpacity={0.7}>
              <Ionicons name="checkmark" size={20} color={theme.colors.primary} />
            </TouchableOpacity>
          </View>
        ) : (
          <TouchableOpacity
            onPress={() => {
              setEditName(outfit.name);
              setShowEditName(true);
            }}
            activeOpacity={0.7}
          >
            <Text style={styles.headerTitle} numberOfLines={1}>
              {outfit.name}
            </Text>
            <View style={styles.editHint}>
              <Ionicons name="create-outline" size={12} color={theme.colors.textTertiary} />
              <Text style={styles.editHintText}>点击改名</Text>
            </View>
          </TouchableOpacity>
        )}

        {showSaved ? (
          <View style={styles.savedIndicator}>
            <Ionicons name="checkmark" size={18} color={theme.colors.success} />
            <Text style={styles.savedText}>已保存</Text>
          </View>
        ) : (
          <View style={styles.headerRight}>
            {hasUnsavedChanges && (
              <TouchableOpacity
                style={styles.saveBtn}
                onPress={handleSavePositions}
                disabled={isSaving}
                activeOpacity={0.7}
              >
                <Text style={styles.saveBtnText}>{isSaving ? '保存中...' : '保存'}</Text>
              </TouchableOpacity>
            )}
            <TouchableOpacity onPress={handleDeleteOutfit} activeOpacity={0.7}>
              <Ionicons name="trash-outline" size={22} color={theme.colors.textSecondary} />
            </TouchableOpacity>
          </View>
        )}
      </View>

      {/* Canvas */}
      <View style={[styles.canvas, { width: canvasWidth, height: canvasHeight }]}>
        {outfitItems.length === 0 ? (
          <View style={styles.emptyCanvas}>
            <Ionicons name="images-outline" size={48} color={theme.colors.border} />
            <Text style={styles.emptyCanvasText}>画板是空的</Text>
            <Text style={styles.emptyCanvasSubtext}>从下方拖入衣服到画板</Text>
          </View>
        ) : (
          outfitItems.map(renderCanvasItem)
        )}
      </View>

      {/* Bottom Strip */}
      <View style={styles.bottomStrip}>
        <Text style={styles.stripLabel}>
          点击衣服加入画板 · {availableClothing.length} 件可用
        </Text>
        <ScrollView
          horizontal
          showsHorizontalScrollIndicator={false}
          contentContainerStyle={styles.stripScroll}
        >
          {availableClothing.map((item: any) => (
            <TouchableOpacity
              key={item.id}
              style={styles.stripItem}
              onPress={() => handleAddFromStrip(item)}
              activeOpacity={0.7}
            >
              <Image source={{ uri: item.thumbnailUri }} style={styles.stripImage} />
              <View style={styles.stripItemOverlay}>
                <Ionicons name="add" size={16} color={theme.colors.white} />
              </View>
            </TouchableOpacity>
          ))}
          {availableClothing.length === 0 && (
            <View style={styles.stripEmpty}>
              <Text style={styles.stripEmptyText}>所有衣服已在画板中</Text>
            </View>
          )}
        </ScrollView>
      </View>
    </View>
  );
}

// 单个画板衣物组件：拖动 + 点击显示删除按钮
function CanvasItem({
  item,
  itemId,
  initialX,
  initialY,
  initialScale,
  size,
  onPositionChange,
  onRemove,
}: {
  item: ClothingItem;
  itemId: number;
  initialX: number;
  initialY: number;
  initialScale: number;
  size: number;
  onPositionChange: (x: number, y: number, scale: number) => void;
  onRemove: () => void;
}) {
  const safeX = Number.isFinite(initialX) ? initialX : 0;
  const safeY = Number.isFinite(initialY) ? initialY : 0;
  const safeScale = Number.isFinite(initialScale) ? initialScale : 1;

  // 用 ref 跟踪当前位置，避免闭包陷阱
  const currentX = useRef(safeX);
  const currentY = useRef(safeY);
  const currentScaleVal = useRef(safeScale);
  const pan = useRef(new Animated.ValueXY({ x: safeX, y: safeY })).current;
  const scaleAnim = useRef(new Animated.Value(safeScale)).current;
  const [showRemove, setShowRemove] = useState(false);

  const panResponder = useRef(
    PanResponder.create({
      onStartShouldSetPanResponder: () => true,
      onMoveShouldSetPanResponder: () => true,
      onPanResponderMove: (_, gestureState) => {
        pan.setValue({
          x: currentX.current + gestureState.dx,
          y: currentY.current + gestureState.dy,
        });
      },
      onPanResponderRelease: (_, gestureState) => {
        const newX = currentX.current + gestureState.dx;
        const newY = currentY.current + gestureState.dy;
        currentX.current = newX;
        currentY.current = newY;
        Animated.spring(pan, {
          toValue: { x: newX, y: newY },
          useNativeDriver: false,
        }).start();
        onPositionChange(newX, newY, currentScaleVal.current);
      },
    })
  ).current;

  const toggleRemove = () => setShowRemove((v) => !v);

  return (
    <Animated.View
      style={[
        styles.canvasItem,
        { width: size, height: size },
        {
          transform: [
            ...pan.getTranslateTransform(),
            { scale: scaleAnim },
          ],
        },
      ]}
      {...panResponder.panHandlers}
    >
      <TouchableOpacity activeOpacity={0.9} onPress={toggleRemove} style={{ flex: 1 }}>
        <Image source={{ uri: item.thumbnailUri }} style={styles.canvasImage} />
      </TouchableOpacity>
      {showRemove && (
        <TouchableOpacity
          style={styles.canvasRemoveBtn}
          onPress={onRemove}
          hitSlop={{ top: 10, bottom: 10, left: 10, right: 10 }}
        >
          <Ionicons name="close-circle" size={24} color={theme.colors.danger} />
        </TouchableOpacity>
      )}
    </Animated.View>
  );
}

